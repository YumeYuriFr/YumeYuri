import type { GetStaticPathsOptions, Page } from 'astro';
import { getPermalink } from '~/utils/permalinks';
import SearchBar from '~/components/ui/SearchBar.astro';
import type { SearchItem } from '~/components/ui/SearchBar.astro';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  return paginate(contentList, { pageSize: 15 });
}

interface Props {
  page: Page<(typeof contentList)[number]>;
}

const { page } = Astro.props as Props;
const entries = page.data;
const metadata = { title: `Liste Yuri — Page ${page.currentPage}` };

const searchItems: SearchItem[] = contentList.map((entry) => ({
  title: entry.title,
  author: entry.author,
  publisher: entry.publisher,
  status: entry.status,
  volumesFR: entry.volumesFR,
  volumesJP: entry.volumesJP,
  synopsis: entry.synopsis,
  subGenre: entry.subGenre,
  shopLinks: entry.shopLinks,
  imageSrc: (covers[entry.coverLink as keyof typeof covers] || placeholder).src,
  imageAlt: entry.image?.alt || '',
}));
---

<Layout metadata={metadata}>
  <SearchBar items={searchItems} />

  <div id="static-list-content">
    {
      entries.map((entry, index) => (
        <Content
          image={{
            src: covers[entry.coverLink as keyof typeof covers] || placeholder,
            alt: entry.image?.alt || '',
          }}
          isReversed={index % 2 === 1}
          isAfterContent={index % 3 === 0}
        >
          <div slot="content">
            <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
              {entry.title} - {entry.author}
            </h3>
            <p>
              Status : <span class="text-pink-200">{entry.status}</span>
            </p>
            <p>
              Tomes disponible FR : <span class="text-pink-200">{entry.volumesFR}</span> | JP :{' '}
              <span class="text-pink-200">{entry.volumesJP}</span>
            </p>
            <p>
              Éditeur : <span class="text-pink-200">{entry.publisher}</span>
            </p>
            {entry.subGenre && (
              <p>
                Sous-genre : <span class="text-pink-200">{entry.subGenre}</span>
              </p>
            )}
            <p class="mt-2">{entry.synopsis}</p>
            <div class="mt-3 space-x-3">
              {Object.entries(entry.shopLinks).map(([shopName, url]) => (
                <a href={url} target="_blank" rel="noopener noreferrer" class="text-pink-200 hover:underline">
                  {shopName}
                </a>
              ))}
            </div>
          </div>
        </Content>
      ))
    }
  </div>

  <div id="pagination-nav">
    <Pagination currentPage={page.currentPage} totalPages={page.lastPage} basePath={getPermalink('ListeYuri')} />
  </div>

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Discord',
        href: 'https://discord.gg/YyG3CmHTWh',
        target: '_blank',
        icon: 'tabler:brand-discord',
      },
    ]}
  >
    <div slot="title">Un titre manquant ?</div>
    <div slot="subtitle">Merci de nous le signaler sur notre discord !</div>
  </CallToAction>
</Layout>
