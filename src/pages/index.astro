---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features2 from '~/components/widgets/Features2.astro';
import heroBg from '~/assets/images/test.png';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Bienvenus dans votre sanctuaire du yuri',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero id="hero-section">
    <Fragment slot="title"> Bienvenus dans votre sanctuaire du yuri </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline"> <span class="font-semibold">Yumi Yuri</span> votre sanctuaire du Yuri</span>
      <span class="block mb-1 sm:hidden font-bold text-blue-600"> </span>
      Un monde magique et de rêve est à présent ici. Rien ne presse tout est là.
    </Fragment>

    <Fragment slot="bg">
      <div
        style={`background-image: url('${heroBg.src}'); background-attachment: fixed; background-size: cover; background-position: center;`}
        class="absolute inset-0"
      >
      </div>
      <div class="absolute inset-0 bg-black/40"></div>
      <a
        href="#after-hero"
        class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/80 hover:text-white transition-colors"
      >
        <span class="text-sm tracking-widest uppercase">Découvrir</span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-6 h-6 animate-bounce"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
        </svg>
      </a>
    </Fragment>
  </Hero>

  <div id="after-hero"></div>

  <style>
    #hero-section {
      min-height: 100vh;
    }
  </style>

  <!-- FAQs Widget ******************* -->
  <Features2
    title="A propos de nous"
    subtitle="Passionnées par le yuri, nous avons créé ce sanctuaire pour partager notre amour et nos découvertes. Faciliter la découverte de nouveaux titres et de nouvelles histoires en français, ainsi que la promotion des œuvres de yuri. Créer un espace où les fans peuvent se rassembler, discuter et partager leur passion pour le yuri. En savoir plus ? <a href='/Presentation' class='text-pink-300 hover:underline'>Lire notre présentation →</a>"
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-page dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <FAQs
    title="Questions pour ce sanctuaire ?"
    subtitle="Vous trouverez ici les réponses à vos questions les plus fréquentes."
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: "Qu'est ce que le genre Yuri ?",
        description:
          "Le genre Yuri, également connu sous le nom de 'shoujo-ai', est un genre de fiction qui met en avant des relations romantiques et émotionnelles entre des personnages féminins. Il explore les thèmes de l'amour, de l'amitié et de la découverte de soi à travers les yeux de femmes.",
      },
      {
        title: 'Comment découvrir le Yuri ?',
        description:
          "Pour s'initier au yuri, regarder les adaptations animées est fréquemment une approche très efficace, malgré une offre assez faible: nous pouvons tout de même retrouver des titres notables comme « Citrus », « Bloom Into You » ou « Adachi to Shimamura ». Pour une immersion plus poussée dans l'univers du yuri, il est hautement préférable de consulter les sources d'origine des adaptations évoquées, ou encore de vous plonger dans des œuvres qui n'ont connu ni adaptation, et qui n'en connaîtront probablement jamais.",
      },
      {
        title: 'Comment classifions nous les Yuri ?',
        description:
          "Il existe de nombreuses sous-catégories de yuri :<br><br><b>Soft Yuri</b> : romance douce avec peu ou pas du tout de relations sexuelles (exemple : Bloom Into You)<br><b>Light Yuri</b> : relations sous-entendues ou non canon (exemple : Bocchi the Rock!)<br><b>Moe/Slice of Life</b> : relations mignonnes et légères (exemple : Miss Kobayashi's Dragon Maid)<br><b>Toxic Yuri</b> : fascination morbide, sentiment d'appropriation, dynamique toxique (exemple : Happy Sugar Life)<br><b>Adult Yuri</b> : saga intime explorant les complexités relationnelles et les enjeux de la vie adulte (exemple : Nos Différences Enlacées)<br><b>Explicit Yuri</b> : contenu explicitement pornographique (exemple : Shoujo Sect)<br><b>Yuri Fantasy/SF</b> : Relations amoureuses dans des cadres fantastiques ou de science-fiction. (exemple : I'm in Love with the Villainess)",
      },
      {
        title: 'Qui sont les principaux éditeurs de Yuri en France ?',
        description:
          "Taifu Comics et Meian dominent le paysage de l'édition yuri en France. Le premier est un pionnier du genre avec des titres comme « Citrus », « Netsuzu TRap -NTR- » ou « Whispering You a Love Song ». Pour sa part, le second a présenté dernièrement un ensemble de nouveautés : des séries comme « Notre été éphémère », « This Monster Wants to Eat Me » ou « Adachi & Shimamura ». Des maisons d'édition généralistes, moins axées sur la niche, ont déjà publié des mangas similaires, telles que Kana avec le très apprécié « Bloom Into You », Kazé/Crunchyroll avec « The Magical Revolution – La Princesse réincarnée et la jeune prodige » et noeve grafx avec « Happy Sugar Life ».",
      },
    ]}
  />

  <!-- Stats Widget ****************** -->

  <Stats
    stats={[
      { title: 'Nombre de Titre Yuri', amount: '132' },
      { title: 'Nombre de tome en france', amount: '948' },
      { title: 'Membre sur le discord', amount: '10' },
      { title: 'Temps que adachi mette à répondre', amount: '48.4K' },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Discord',
        href: 'https://discord.gg/YyG3CmHTWh',
        target: '_blank',
        icon: 'tabler:brand-discord',
      },
    ]}
  >
    <Fragment slot="title"> Envie de discuté yuri ? </Fragment>

    <Fragment slot="subtitle">
      Pour en découvrir plus sur l'univers du yuri, n'hésitez pas à nous rejoindre sur notre serveur Discord.
    </Fragment>
  </CallToAction>
</Layout>
