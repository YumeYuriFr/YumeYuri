---
import '@fontsource-variable/inter';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    /* Thème principal: remplacer les bleus par du rose (cohérent avec les boutons) */
    --aw-color-primary: rgb(236 72 153); /* pink-500 */
    --aw-color-secondary: rgb(219 39 119); /* pink-600 */
    --aw-color-accent: rgb(168 85 247); /* violet-500, conserve un accent */

    /* Forcer texte clair par défaut (blanc cassé) */
    --aw-color-text-heading: rgb(247, 248, 248);
    --aw-color-text-default: rgb(229 236 246);
    --aw-color-text-muted: rgb(229 236 246 / 66%);
    /* Compatibilité avec utilitaires qui utilisent --aw-color-text-page */
    --aw-color-text-page: var(--aw-color-text-default);
    --aw-color-bg-page: #1c1117;

    --aw-color-bg-page-dark: #1c1117;

    ::selection {
      background-color: lavender;
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    /* Dark mode: mêmes valeurs pour cohérence (ou ajuster si besoin) */
    --aw-color-primary: rgb(236 72 153); /* pink-500 */
    --aw-color-secondary: rgb(219 39 119); /* pink-600 */
    --aw-color-accent: rgb(168 85 247); /* violet-500 */

    --aw-color-text-heading: rgb(247, 248, 248);
    --aw-color-text-default: rgb(229 236 246);
    --aw-color-text-muted: rgb(229 236 246 / 66%);
    --aw-color-text-page: var(--aw-color-text-default);
    --aw-color-bg-page: #1c1117;

    ::selection {
      background-color: black;
      color: snow;
    }
  }
</style>
