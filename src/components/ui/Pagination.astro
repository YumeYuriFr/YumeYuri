---
interface Props {
  currentPage: number;
  totalPages: number;
  basePath: string;
}

const { currentPage, totalPages, basePath } = Astro.props;
const prev = currentPage > 1 ? `${basePath}/${currentPage - 1}` : null;
const next = currentPage < totalPages ? `${basePath}/${currentPage + 1}` : null;
const pages = Array.from({ length: totalPages }, (_, i) => i + 1);
---

<nav class="flex justify-center items-center gap-2 py-8 flex-wrap" aria-label="Pagination">
  {
    prev ? (
      <a
        href={prev}
        class="px-3 py-1 rounded border border-pink-300 text-pink-300 hover:bg-pink-300 hover:text-white transition-colors"
      >
        ←
      </a>
    ) : (
      <span class="px-3 py-1 rounded border border-gray-600 text-gray-600 cursor-not-allowed">←</span>
    )
  }

  {
    pages.map((p) => (
      <a
        href={`${basePath}/${p}`}
        class={`px-3 py-1 rounded border transition-colors ${
          p === currentPage
            ? 'bg-pink-400 border-pink-400 text-white font-bold'
            : 'border-pink-300 text-pink-300 hover:bg-pink-300 hover:text-white'
        }`}
        aria-current={p === currentPage ? 'page' : undefined}
      >
        {p}
      </a>
    ))
  }

  {
    next ? (
      <a
        href={next}
        class="px-3 py-1 rounded border border-pink-300 text-pink-300 hover:bg-pink-300 hover:text-white transition-colors"
      >
        →
      </a>
    ) : (
      <span class="px-3 py-1 rounded border border-gray-600 text-gray-600 cursor-not-allowed">→</span>
    )
  }
</nav>
